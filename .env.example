# ============================================================
# Student Application Portal — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Database (Supabase) ----
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---- IDfy API ----
IDFY_API_KEY=your_idfy_api_key
IDFY_ACCOUNT_ID=your_idfy_account_id
IDFY_BASE_URL=https://api.idfy.io
IDFY_CREATE_TASK_URL=/v1/tasks/async/verify_with_source/ind_aadhaar_digilocker
IDFY_GET_TASK_URL=/v1/tasks

# ---- URLs ----
# Your Render backend URL (after deployment)
BACKEND_URL=https://student-portal-backend.onrender.com
# Your Vercel frontend URL (after deployment)
FRONTEND_URL=https://student-portal.vercel.app
