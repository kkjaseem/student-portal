# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend URL (for CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Database (Supabase connection string) ────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── IDfy Credentials ─────────────────────────────────────────────
# From your IDfy dashboard / eve.support@idfy.com
IDFY_API_KEY=your_api_key_here
IDFY_ACCOUNT_ID=your_account_id_here          # e.g. 123/123456

# From IDfy's one-time setup for ind_digilocker_fetch_documents
IDFY_KEY_ID=your_key_id_here                  # e.g. 3e281012-449b-4305-be16-7999ed7c65c6
IDFY_OU_ID=your_ou_id_here                    # e.g. 731b23f196a7
IDFY_SECRET=your_base64_encoded_secret_here   # base64 encode your raw secret before pasting

# ── Public backend URL (used as IDfy callback_url) ───────────────
# Local dev: use your ngrok URL  e.g. https://abc123.ngrok-free.app
# Production: your Render URL    e.g. https://student-portal-backend.onrender.com
BACKEND_URL=https://your-backend-url.onrender.com

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
